VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
VITE_API_BASE_URL=https://api.ministryofpapers.com
VITE_ADMIN_EMAILS=you@example.com

# Google Analytics 4 measurement ID (get from GA console → Admin → Data Streams → your stream)
# Format: G-XXXXXXXXXX   Leave empty to disable
VITE_GA_MEASUREMENT_ID=G-22RVRV3S86

# Microsoft Clarity project ID (Clarity dashboard → Settings → Overview → Project ID)
# Format: short alphanumeric, e.g. abcd1234ef   Leave empty to disable.
# Only loads in production builds, lazily after the page is idle (same as GA).
VITE_CLARITY_PROJECT_ID=

